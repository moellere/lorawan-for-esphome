# Per-device LoRaWAN registration keys. Copy to `lorawan-secrets.yaml` (which is
# gitignored) and fill in real values -- never commit the filled copy.
#
# ESPHome's !secret only reads a file literally named secrets.yaml, so wire this
# in by merge-including it from your main secrets.yaml:
#
#   # secrets.yaml
#   <<: !include lorawan-secrets.yaml
#   wifi_ssid: "..."
#   wifi_password: "..."
#
# A device config then references its own namespaced keys:
#
#   # kitchen.yaml
#   lorawan:
#     dev_eui: !secret kitchen_dev_eui
#     join_eui: !secret kitchen_join_eui
#     app_key: !secret kitchen_app_key
#
# Keys are MSB hex (matches the ChirpStack UI and RadioLib). DevEUI and JoinEUI
# are 16 hex digits; AppKey is 32. Give each device a unique <node>_ prefix;
# substitutions cannot be used inside !secret, so the prefix is spelled out per
# device.

kitchen_dev_eui:  "0000000000000000"
kitchen_join_eui: "0000000000000000"
kitchen_app_key:  "00000000000000000000000000000000"

porch_dev_eui:  "0000000000000000"
porch_join_eui: "0000000000000000"
porch_app_key:  "00000000000000000000000000000000"
